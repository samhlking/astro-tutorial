---
import Navigation from './Navigation.astro';
import Menu from './Menu.astro';
import ThemeIcon from './ThemeIcon.astro';
---
<header class="pb-6">
  <nav>
    <Navigation />
    <div>
      <Menu />
      <ThemeIcon />
    </div>
  </nav>
</header>

<style>
  nav {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
  }
</style>