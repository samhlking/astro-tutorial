---
import { getCollection } from "astro:content";
import Layout from '../../layouts/Layout.astro';
const allPosts = await getCollection("blog");
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
const pageTitle = "Tag Index";
---
<Layout pageTitle={pageTitle}>
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
        <a href={`/astro-tutorial/tags/${tag}`} class="px-3 py-1.5 bg-stone-100 border border-stone-300 text-stone-700 dark:bg-stone-800 dark:border-stone-700 dark:text-stone-300 rounded-full text-sm hover:bg-stone-200 hover:border-stone-400 dark:hover:bg-stone-700 dark:hover:border-stone-500 focus:outline-none focus:ring-2 focus:ring-accent transition-colors">{tag}</a>
    ))}
  </div>
</Layout>