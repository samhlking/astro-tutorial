---
import Layout from '../layouts/Layout.astro';
import Greeting from '../components/Greeting';
import { getCollection } from "astro:content";
const allPosts = await getCollection("blog");
const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];
const pageTitle = "Sam's Astro Tutorial";
---

<Layout pageTitle={pageTitle}>
	<section class="mb-12">
		<Greeting client:load messages={["Hi", "Hej", "Hallo", "Hola", "Habari"]} />
		<div class="mt-6 space-y-4 text-grey leading-relaxed max-w-prose">
			<p>
			Nostrud aliquip ullamco velit magna incididunt. Fugiat eiusmod eiusmod ex do.
			</p>
			<p>
			Sunt culpa voluptate aliquip laboris ullamco aliqua minim nostrud tempor nisi ea tempor reprehenderit. Aliquip voluptate in ut occaecat ut culpa esse consequat.
			</p>
			<p>
			Get in touch at <a href="mailto:sam@samuel-king.com" class="text-accent hover:underline underline-offset-4 transition-colors">sam@samuel-king.com</a>
			</p>
		</div>
	</section>
  
	<section>
	  <h2>Writing about</h2>
	  <div class="flex flex-wrap gap-2">
		{tags.map((tag) => (
			<a href={`/astro-tutorial/tags/${tag}`} class="px-3 py-1.5 bg-stone-100 border border-stone-300 text-stone-700 dark:bg-stone-800 dark:border-stone-700 dark:text-stone-300 rounded-full text-sm hover:bg-stone-200 hover:border-stone-400 dark:hover:bg-stone-700 dark:hover:border-stone-500 focus:outline-none focus:ring-2 focus:ring-accent transition-colors">{tag}</a>
		))}
	  </div>
	</section>
  </Layout>