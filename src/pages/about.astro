---
import Layout from '../layouts/Layout.astro';

const pageTitle = "About Me";

const identity = {
  firstName: "Sam",
  country: "UK",
  occupation: "Freelance Web Designer",
  hobbies: ["photography", "travel", "rugby"],
};

const skills = ["HTML", "CSS", "JavaScript", "React", "Astro", "Writing Docs"];

const happy = true;
const finished = true;
const goal = 3;

const skillColor = "crimson";
---

<Layout pageTitle={pageTitle}>
        
        <h1>{pageTitle}</h1>
        <p>Dolore sunt qui eiusmod exercitation ea ex. Eiusmod dolor ad velit excepteur qui nulla consequat pariatur sit id ipsum. Nulla occaecat do exercitation ad. Consectetur sit reprehenderit occaecat aute aute quis in.</p>
        <h2>Currently working on...</h2>
        <ol>
            <li><a href="https://samuel-king.com" target="_blank">Freelance Web Development</a></li>
            <li>AI Research</li>
            <li>Something else...</li>
        </ol>
		<p>Here are a few facts about me:</p>
		<ul>
			<li>My name is {identity.firstName}.</li>
			<li>I live in {identity.country} and I work as a {identity.occupation}.</li>
			{identity.hobbies.length >= 2 &&
				<li>Two of my hobbies are: {identity.hobbies[0]} and {identity.hobbies[1]}</li>
			}
		</ul>
		<p>My skills are:</p>
		<ul>
			{skills.map((skill) => <li class="skill">{skill}</li>)}
		</ul>
		{happy && <p>I am happy to be learning Astro!</p>}

		{finished && <p>I finished this tutorial!</p>}

		{goal === 3 ? <p>My goal is to finish in 3 days.</p> : <p>My goal is not 3 days.</p>}
</Layout>